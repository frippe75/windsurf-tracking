# API Configuration
# Set to 'true' to use mock API endpoints instead of real backend
# Useful for development without running the actual backend
VITE_USE_MOCK_API=false


# FastAPI Backend URL
# Leave empty to auto-detect based on environment:
#   - Production build: https://lablebee.tclab.org
#   - Development: http://localhost:8000
# Override with custom URL if needed:
# VITE_BACKEND_URL=http://localhost:8000
# VITE_BACKEND_URL=https://lablebee.tclab.org
