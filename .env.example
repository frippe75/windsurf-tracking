# API Configuration
# Set to 'true' to use mock API endpoints instead of real backend
# Useful for development without running the actual backend
VITE_USE_MOCK_API=false

# Supabase Configuration (provided by Lovable)
# VITE_SUPABASE_URL=your-supabase-url
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Local Backend URL (for local development)
# VITE_LOCAL_BACKEND_URL=http://localhost:3000
